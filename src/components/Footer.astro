---
const currentYear = new Date().getFullYear();

const navItems = [
  { label: 'Start Here',    href: '/' },
  { label: 'About Us',      href: '/about' },
  { label: 'Our Services',  href: '/services' },
  { label: 'Past Projects', href: '/projects' },
  { label: 'Contact Us',    href: '/contact' },
];
---

<footer class="footer">
  <div class="footer__inner container--wide">

    <div class="footer__brand">
      <a href="/">
        <img src="/logo.png" alt="Best Top Exteriors" width="180" />
      </a>
      <p class="footer__tagline">Serving Wichita, KS &amp; Surrounding Areas</p>
      <a href="tel:3168699613" class="footer__phone">316-869-9613</a>
    </div>

    <div class="footer__nav">
      <h4>Quick Links</h4>
      <ul>
        {navItems.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__services">
      <h4>Services</h4>
      <ul>
        <li>Roofing &amp; Storm Repairs</li>
        <li>Insurance Claim Assistance</li>
        <li>Gutters &amp; Soffit / Fascia</li>
        <li>Siding</li>
        <li>Interior &amp; Exterior Painting</li>
        <li>Power Washing</li>
        <li>Fence Repairs</li>
        <li>Window &amp; Trim Wrapping</li>
        <li>Pre-Sale Inspections</li>
      </ul>
    </div>

    <div class="footer__contact">
      <h4>Get in Touch</h4>
      <p>Wichita, KS &amp; Surrounding Areas</p>
      <a href="tel:3168699613">316-869-9613</a>
      <a href="/contact" class="btn btn--primary footer__cta">Free Estimate</a>
    </div>

  </div>

  <div class="footer__bottom">
    <p>&copy; {currentYear} Best Top Exteriors. All rights reserved.</p>
    <p>Website design &amp; development by <a href="https://selahcreate.com" target="_blank" rel="noopener">Selah Create: Digital Design</a>.</p>
  </div>
</footer>

<style>
.footer {
  background: var(--color-white);
  border-top: 3px solid var(--color-navy);
}

.footer__inner {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2.5rem;
  padding: 3.5rem 2rem 2.5rem;
}

.footer__brand {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.footer__tagline {
  font-size: 0.9rem;
  color: var(--text-light);
}

.footer__phone {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--color-red);
  text-decoration: none;
}

.footer__phone:hover {
  color: var(--color-navy);
}

.footer__nav h4,
.footer__services h4,
.footer__contact h4 {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-navy);
  margin-bottom: 0.75rem;
}

.footer__nav ul,
.footer__services ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.footer__nav a {
  font-size: 0.95rem;
  color: var(--text-mid);
  text-decoration: none;
  transition: color 0.2s;
}

.footer__nav a:hover {
  color: var(--color-red);
}

.footer__services li {
  font-size: 0.95rem;
  color: var(--text-mid);
}

.footer__contact {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.footer__contact p,
.footer__contact a:not(.btn) {
  font-size: 0.95rem;
  color: var(--text-mid);
  text-decoration: none;
}

.footer__contact a:not(.btn):hover {
  color: var(--color-red);
}

.footer__cta {
  margin-top: 0.5rem;
  text-align: center;
}

/* Bottom bar */
.footer__bottom {
  background: var(--color-navy);
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 2rem;
}

.footer__bottom p,
.footer__bottom a {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.7);
}

.footer__bottom a:hover {
  color: var(--color-white);
}
</style>
