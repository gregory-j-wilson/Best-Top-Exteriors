---
const navItems = [
  { label: 'Start Here',    href: '/' },
  { label: 'About Us',      href: '/about' },
  { label: 'Our Services',  href: '/services' },
  { label: 'Past Projects', href: '/projects' },
  { label: 'Contact Us',    href: '/contact' },
];

const { pathname } = Astro.url;
---

<!-- ── DESKTOP SIDEBAR (≥1024px) ─────────────────────────── -->
<aside class="site-sidebar" role="navigation" aria-label="Main navigation">
  <div class="sidebar-logo">
    <a href="/">
      <img src="/logo.png" alt="Best Top Exteriors" width="200" />
    </a>
  </div>

  <nav class="sidebar-nav">
    <ul>
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={['sidebar-nav__link', { 'is-active': pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar-cta">
    <a href="tel:3168699613" class="sidebar-phone">316-869-9613</a>
    <a href="/contact" class="btn btn--primary sidebar-btn">Free Estimate</a>
  </div>
</aside>

<!-- ── TABLET / MOBILE TOP BAR (< 1024px) ────────────────── -->
<header class="topbar" role="banner">

  <!-- Tablet: centered logo + hamburger on right -->
  <div class="topbar__inner">
    <div class="topbar__logo">
      <a href="/">
        <img src="/logo.png" alt="Best Top Exteriors" height="60" />
      </a>
    </div>

    <button
      class="hamburger"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="hamburger-btn"
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <!-- Mobile menu drawer -->
  <nav id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <ul>
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={['mobile-menu__link', { 'is-active': pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="tel:3168699613" class="mobile-menu__phone">316-869-9613</a>
    <a href="/contact" class="btn btn--primary mobile-menu__cta">Free Estimate</a>
  </nav>
</header>

<!-- ── STYLES ─────────────────────────────────────────────── -->
<style>
/* ── Sidebar (desktop) ─────────────────────────────────── */
.site-sidebar {
  display: none;
}

@media (min-width: 1024px) {
  .site-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-width, 260px);
    height: 100vh;
    background: var(--color-white);
    border-right: 2px solid var(--gray-200, #E8E8E8);
    z-index: 100;
    overflow-y: auto;
  }
}

.sidebar-logo {
  padding: 1.75rem 1.5rem 1rem;
  border-bottom: 1px solid var(--gray-200, #E8E8E8);
}

.sidebar-logo img {
  width: 100%;
  max-width: 200px;
}

/* ── Sidebar nav ─────────────────────────────────────── */
.sidebar-nav {
  flex: 1;
  padding: 1rem 0;
}

.sidebar-nav ul {
  list-style: none;
}

.sidebar-nav__link {
  display: block;
  padding: 0.85rem 1.5rem;
  font-family: var(--font-heading, 'Lexend Deca', sans-serif);
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--color-navy, #1B3566);
  text-decoration: none;
  border-left: 4px solid transparent;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
  letter-spacing: 0.01em;
  text-transform: uppercase;
}

.sidebar-nav__link:hover,
.sidebar-nav__link.is-active {
  background: var(--gray-50, #F9F9F9);
  border-left-color: var(--color-red, #CC2222);
  color: var(--color-red, #CC2222);
}

/* ── Sidebar CTA ─────────────────────────────────────── */
.sidebar-cta {
  padding: 1.5rem;
  border-top: 1px solid var(--gray-200, #E8E8E8);
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.sidebar-phone {
  font-family: var(--font-heading, 'Lexend Deca', sans-serif);
  font-weight: 700;
  font-size: 1.05rem;
  color: var(--color-red, #CC2222);
  text-align: center;
  letter-spacing: 0.02em;
  text-decoration: none;
}

.sidebar-phone:hover {
  color: var(--color-navy, #1B3566);
}

.sidebar-btn {
  text-align: center;
  width: 100%;
}

/* ── Top bar (tablet/mobile) ─────────────────────────── */
.topbar {
  display: none;
  background: var(--color-white);
  border-bottom: 2px solid var(--gray-200, #E8E8E8);
  position: sticky;
  top: 0;
  z-index: 200;
  width: 100%;
}

@media (max-width: 1023px) {
  .topbar {
    display: block;
  }
}

.topbar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1.5rem;
}

/* Tablet: center the logo */
@media (min-width: 600px) and (max-width: 1023px) {
  .topbar__inner {
    justify-content: center;
    position: relative;
  }

  .topbar__logo {
    display: flex;
    justify-content: center;
    flex: 1;
  }

  .hamburger {
    position: absolute;
    right: 1.5rem;
  }
}

/* Mobile: logo full-width row, hamburger below or inline */
@media (max-width: 599px) {
  .topbar__inner {
    flex-direction: row;
    justify-content: space-between;
  }

  .topbar__logo img {
    height: 52px;
  }
}

/* ── Hamburger button ─────────────────────────────────── */
.hamburger {
  background: var(--color-navy, #1B3566);
  border: none;
  border-radius: 6px;
  cursor: pointer;
  padding: 10px 12px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 6px;
  width: 52px;
  height: 52px;
  flex-shrink: 0;
  transition: background 0.2s;
}

.hamburger:hover {
  background: var(--color-blue, #1E5FAD);
}

.hamburger__bar {
  display: block;
  width: 28px;
  height: 4px;
  background: var(--color-white);
  border-radius: 3px;
  transition: transform 0.3s ease, opacity 0.3s ease;
  transform-origin: center;
}

/* Open state: animate to X */
.hamburger.is-open .hamburger__bar:nth-child(1) {
  transform: translateY(10px) rotate(45deg);
}

.hamburger.is-open .hamburger__bar:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}

.hamburger.is-open .hamburger__bar:nth-child(3) {
  transform: translateY(-10px) rotate(-45deg);
}

/* ── Mobile menu drawer ───────────────────────────────── */
.mobile-menu {
  background: var(--color-white);
  border-top: 1px solid var(--gray-200, #E8E8E8);
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.35s ease, padding 0.35s ease;
  padding: 0 1.5rem;
}

.mobile-menu.is-open {
  max-height: 600px;
  padding: 1rem 1.5rem 1.5rem;
}

.mobile-menu ul {
  list-style: none;
  border-bottom: 1px solid var(--gray-200, #E8E8E8);
  padding-bottom: 1rem;
  margin-bottom: 1rem;
}

.mobile-menu__link {
  display: block;
  padding: 0.75rem 0;
  font-family: var(--font-heading, 'Lexend Deca', sans-serif);
  font-weight: 700;
  font-size: 1rem;
  color: var(--color-navy, #1B3566);
  text-decoration: none;
  text-transform: uppercase;
  border-bottom: 1px solid var(--gray-100, #F2F2F2);
  transition: color 0.2s;
}

.mobile-menu__link:last-child {
  border-bottom: none;
}

.mobile-menu__link:hover,
.mobile-menu__link.is-active {
  color: var(--color-red, #CC2222);
}

.mobile-menu__phone {
  display: block;
  font-family: var(--font-heading, 'Lexend Deca', sans-serif);
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--color-red, #CC2222);
  text-align: center;
  margin-bottom: 0.75rem;
  text-decoration: none;
}

.mobile-menu__cta {
  display: block;
  text-align: center;
  width: 100%;
}
</style>

<!-- ── SCRIPT ──────────────────────────────────────────────────── -->
<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = btn.classList.toggle('is-open');
      menu.classList.toggle('is-open', isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        btn.classList.remove('is-open');
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
      });
    });
  }
</script>
