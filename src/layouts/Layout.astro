---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Best Top Exteriors — Roofing, Gutters, Siding & Painting. Serving Wichita, KS & Surrounding Areas. Call 316-869-9613.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
<link rel="icon" type="image/png" href="/logo.png" />
    <title>{title} | Best Top Exteriors</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <div class="site-wrapper">
      <Header />

      <div class="site-main">
        <main class="page-content">
          <slot />
        </main>

        <Footer />
      </div>
    </div>
  </body>
</html>

<style is:global>
  /* Ensure the sidebar and main co-exist on desktop */
  @media (min-width: 1024px) {
    .site-main {
      margin-left: var(--sidebar-width, 260px);
    }
  }
</style>
