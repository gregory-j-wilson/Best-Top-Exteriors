---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us" description="Learn about Best Top Exteriors — Wichita's trusted roofing, gutters, siding, and painting contractor.">

  <!-- Page Hero -->
  <section class="section section--navy page-hero">
    <div class="container">
      <h1>About Best Top Exteriors</h1>
      <p>Local experts. Honest work. Lasting results.</p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="section section--white">
    <div class="container two-col">
      <div class="two-col__text">
        <h2>Our Story</h2>
        <p>Best Top Exteriors was built on a simple belief: every homeowner deserves quality work done by people they can trust. From our very first project in Wichita, we've focused on doing the job right — not just fast.</p>
        <p>We started with roofing and have grown to offer gutters, siding, painting, power washing, and more — because our customers kept asking us to stay involved in their homes. That's the best compliment we know.</p>
        <p>We also work directly with homeowners through the insurance claim process, and we partner with realtors to help sellers get their properties market-ready with free pre-sale inspections.</p>
      </div>
      <div class="two-col__visual story-visual">
        <div class="placeholder-img">
          <span>Photo Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section section--gray100">
    <div class="container">
      <h2 class="section-title">What Drives Us</h2>
      <div class="values">
        <div class="value-item">
          <div class="value-item__num">01</div>
          <h3>Integrity</h3>
          <p>We tell you what we find, charge what we quote, and stand behind every project we complete.</p>
        </div>
        <div class="value-item">
          <div class="value-item__num">02</div>
          <h3>Community</h3>
          <p>Wichita is our home. We care about every neighborhood we work in and the families we serve.</p>
        </div>
        <div class="value-item">
          <div class="value-item__num">03</div>
          <h3>Excellence</h3>
          <p>We use quality materials, skilled crews, and careful attention to detail on every single job.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="section section--gray200">
    <div class="container">
      <h2 class="section-title">Where We Serve</h2>
      <p class="center-text">Based in Wichita, KS — we proudly serve the following areas:</p>
      <ul class="area-list">
        <li>Wichita</li>
        <li>Derby</li>
        <li>Andover</li>
        <li>Haysville</li>
        <li>Mulvane</li>
        <li>Valley Center</li>
        <li>Maize</li>
        <li>Goddard</li>
      </ul>
      <p class="center-text">Don't see your city? <a href="/contact">Give us a call</a> — we may still cover your area.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--navy cta-band">
    <div class="container">
      <h2>Let's Work Together</h2>
      <p>Ready for a free, no-obligation estimate? We'd love to hear from you.</p>
      <a href="/contact" class="btn btn--primary">Contact Us Today</a>
    </div>
  </section>

</Layout>

<style>
.page-hero { text-align: center; }
.page-hero p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin-top: 0.75rem; }

.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}
@media (max-width: 700px) {
  .two-col { grid-template-columns: 1fr; }
}
.two-col__text p + p { margin-top: 1rem; }
.two-col__text h2 { margin-bottom: 1.25rem; }

.placeholder-img {
  background: var(--gray-200);
  border-radius: 8px;
  aspect-ratio: 4/3;
  display: flex;
  align-items: center;
  justify-content: center;
}
.placeholder-img span {
  font-family: var(--font-heading);
  font-size: 0.9rem;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.section-title { text-align: center; margin-bottom: 2.5rem; }

.values {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 2rem;
}
.value-item {
  background: var(--color-white);
  border-radius: 8px;
  padding: 2rem 1.5rem;
  border-top: 4px solid var(--color-blue);
}
.value-item__num {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--gray-300);
  margin-bottom: 0.5rem;
}
.value-item h3 { margin-bottom: 0.5rem; }

.center-text { text-align: center; margin-bottom: 1.5rem; }
.area-list {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.area-list li {
  background: var(--color-white);
  border: 1px solid var(--gray-300);
  border-radius: 100px;
  padding: 0.4rem 1.1rem;
  font-size: 0.95rem;
  color: var(--color-navy);
  font-family: var(--font-heading);
  font-weight: 700;
}

.cta-band { text-align: center; }
.cta-band h2 { color: var(--color-white); margin-bottom: 0.75rem; }
.cta-band p { color: rgba(255,255,255,0.8); margin-bottom: 2rem; }
</style>
