---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us" description="Contact Best Top Exteriors for a free estimate on roofing, gutters, siding, or painting in Wichita, KS.">

  <!-- Hero -->
  <section class="section section--navy page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Get your free, no-obligation estimate today.</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section section--gray100">
    <div class="container contact-grid">

      <!-- Info side -->
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <p>Whether you need a roof inspection, gutter replacement, siding repair, a fresh paint job, or you're getting ready to sell — we'd love to hear from you. Reach out and we'll get back to you promptly.</p>

        <div class="contact-details">
          <div class="contact-detail">
            <div class="contact-detail__label">Phone</div>
            <a href="tel:3168699613" class="contact-detail__value phone-link">316-869-9613</a>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Service Area</div>
            <div class="contact-detail__value">Wichita, KS &amp; Surrounding Areas</div>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Services</div>
            <div class="contact-detail__value">Roofing · Gutters · Siding · Painting · Power Washing · Fence Repairs · Window &amp; Trim Wrapping · Pre-Sale Inspections</div>
          </div>
        </div>
      </div>

      <!-- Form side -->
      <div class="contact-form-wrap">
        <form class="contact-form" name="contact" method="POST" action="/success">
          <div class="form-row">
            <div class="form-group">
              <label for="first-name">First Name <span aria-hidden="true">*</span></label>
              <input type="text" id="first-name" name="first-name" required placeholder="Jane" />
            </div>
            <div class="form-group">
              <label for="last-name">Last Name <span aria-hidden="true">*</span></label>
              <input type="text" id="last-name" name="last-name" required placeholder="Smith" />
            </div>
          </div>

          <div class="form-group">
            <label for="phone">Phone Number <span aria-hidden="true">*</span></label>
            <input type="tel" id="phone" name="phone" required placeholder="(316) 000-0000" />
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" />
          </div>

          <div class="form-group">
            <label for="service">Service Needed</label>
            <select id="service" name="service">
              <option value="">— Select a service —</option>
              <option value="roofing">Roofing</option>
              <option value="insurance">Insurance Claim Assistance</option>
              <option value="gutters">Gutters</option>
              <option value="soffit-fascia">Soffit, Fascia &amp; Trim Repair</option>
              <option value="siding">Siding</option>
              <option value="painting">Interior / Exterior Painting</option>
              <option value="power-washing">Power Washing</option>
              <option value="fence">Fence Repairs</option>
              <option value="window-wrap">Window &amp; Trim Wrapping</option>
              <option value="pre-sale">Pre-Sale Home Inspection</option>
              <option value="multiple">Multiple Services</option>
              <option value="other">Not Sure / Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Tell Us More</label>
            <textarea id="message" name="message" rows="5" placeholder="Describe what you need or any details that would help us..."></textarea>
          </div>

          <button type="submit" class="btn btn--primary form-submit">Send My Request</button>
        </form>
      </div>

    </div>
  </section>

  <!-- Trust bar -->
  <section class="section section--gray200 trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <strong>Free Estimates</strong>
          <span>No cost, no pressure</span>
        </div>
        <div class="trust-item">
          <strong>Local &amp; Trusted</strong>
          <span>Wichita's own crew</span>
        </div>
        <div class="trust-item">
          <strong>Quality Work</strong>
          <span>We take pride in every job</span>
        </div>
        <div class="trust-item">
          <strong>We Stand Behind Our Work</strong>
          <span>Your satisfaction matters</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
.page-hero { text-align: center; }
.page-hero p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin-top: 0.75rem; }

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 3.5rem;
  align-items: start;
}
@media (max-width: 768px) {
  .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
}

.contact-info h2 { margin-bottom: 1rem; }
.contact-info > p { margin-bottom: 2rem; font-size: 1.05rem; }

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.contact-detail__label {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-light);
  margin-bottom: 0.2rem;
}
.contact-detail__value {
  font-size: 1rem;
  color: var(--text-dark);
}
.phone-link {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.4rem;
  color: var(--color-red);
  text-decoration: none;
}
.phone-link:hover { color: var(--color-navy); }

/* Form */
.contact-form-wrap {
  background: var(--color-white);
  border-radius: 10px;
  padding: 2.5rem 2rem;
  border: 1px solid var(--gray-200);
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}
@media (max-width: 500px) {
  .form-row { grid-template-columns: 1fr; }
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.form-group label {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-navy);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.form-group label span {
  color: var(--color-red);
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 0.65rem 0.9rem;
  border: 2px solid var(--gray-300);
  border-radius: 5px;
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--text-dark);
  background: var(--color-white);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--color-blue);
  box-shadow: 0 0 0 3px rgba(30,95,173,0.15);
}

.form-group textarea { resize: vertical; }

.form-submit { width: 100%; justify-content: center; }

/* Trust bar */
.trust-bar { padding: 2.5rem 2rem; }
.trust-items {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem 3rem;
}
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  text-align: center;
}
.trust-item strong {
  font-family: var(--font-heading);
  font-size: 1rem;
  color: var(--color-navy);
}
.trust-item span {
  font-size: 0.9rem;
  color: var(--text-light);
}
</style>
