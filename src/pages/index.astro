---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Start Here">

  <!-- Hero -->
  <section class="section section--navy hero">
    <div class="container">
      <p class="hero__eyebrow">Wichita's Trusted Exterior Experts</p>
      <h1>Your Home Deserves the Best&nbsp;Top</h1>
      <p class="hero__sub">Roofing · Gutters · Siding · Interior &amp; Exterior Painting<br />Serving Wichita, KS &amp; Surrounding Areas</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Get a Free Estimate</a>
        <a href="tel:3168699613" class="btn btn--outline-white">316-869-9613</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section section--gray100">
    <div class="container">
      <h2 class="section-title">Why Homeowners Choose Best Top Exteriors</h2>
      <div class="cards">
        <div class="card">
          <div class="card__icon">🏠</div>
          <h3>Quality Craftsmanship</h3>
          <p>Every job is done right the first time. We take pride in our work on every home we touch.</p>
        </div>
        <div class="card">
          <div class="card__icon">📞</div>
          <h3>Responsive &amp; Reliable</h3>
          <p>We show up when we say we will and communicate every step of the way.</p>
        </div>
        <div class="card">
          <div class="card__icon">💰</div>
          <h3>Fair, Honest Pricing</h3>
          <p>No surprise costs. You get a clear estimate before any work begins.</p>
        </div>
        <div class="card">
          <div class="card__icon">🌟</div>
          <h3>Local &amp; Trusted</h3>
          <p>We're proud to serve our Wichita community and back our work with real warranties.</p>
        </div>
        <div class="card">
          <div class="card__icon">🛡️</div>
          <h3>Insurance Claim Help</h3>
          <p>We work directly with your insurance company to make sure you're treated fairly after storm damage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="section section--white">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      <div class="service-grid">
        <a href="/services" class="service-tile">
          <div class="service-tile__icon">🏚️</div>
          <h3>Roofing</h3>
          <p>New roofs, repairs, and replacements done by experienced local crews.</p>
        </a>
        <a href="/services" class="service-tile">
          <div class="service-tile__icon">🌧️</div>
          <h3>Gutters</h3>
          <p>Installation, cleaning, and guard systems to protect your home year-round.</p>
        </a>
        <a href="/services" class="service-tile">
          <div class="service-tile__icon">🏗️</div>
          <h3>Siding</h3>
          <p>Durable siding solutions that boost curb appeal and weather resistance.</p>
        </a>
        <a href="/services" class="service-tile">
          <div class="service-tile__icon">🎨</div>
          <h3>Painting</h3>
          <p>Interior and exterior painting, plus power washing for your house and wood deck.</p>
        </a>
        <a href="/services#additional" class="service-tile">
          <div class="service-tile__icon">🔧</div>
          <h3>Additional Services</h3>
          <p>Fence repairs, window &amp; trim wrapping, and free pre-sale home inspections.</p>
        </a>
      </div>
      <div class="center-action">
        <a href="/services" class="btn btn--secondary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Selling Your Home -->
  <section class="section section--gray100 sell-band">
    <div class="container sell-band__inner">
      <div class="sell-band__text">
        <h2>Looking to Sell Your Home?</h2>
        <p>We offer free inspections to get your property ready for sale. We're experienced at working with realtors and know exactly what buyers and agents are looking for when it comes to curb appeal and exterior condition.</p>
        <a href="/contact" class="btn btn--secondary">Request a Free Pre-Sale Inspection</a>
      </div>
      <div class="sell-band__icon" aria-hidden="true">🏡</div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="section section--blue cta-band">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Call us today or fill out our quick form — we'll get you a no-pressure free estimate.</p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn--primary">Request Free Estimate</a>
        <a href="/projects" class="btn btn--outline-white">See Our Work</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.hero { text-align: center; }
.hero__eyebrow {
  font-family: var(--font-heading);
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-sky);
  margin-bottom: 1rem;
}
.hero__sub {
  font-size: 1.15rem;
  color: rgba(255,255,255,0.85);
  margin: 1.25rem 0 2rem;
}
.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  margin-top: 1.5rem;
}
.btn--outline-white {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  border-radius: 4px;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1rem;
  background: transparent;
  color: var(--color-white);
  border: 2px solid rgba(255,255,255,0.7);
  text-decoration: none;
  transition: background 0.2s, border-color 0.2s;
}
.btn--outline-white:hover {
  background: rgba(255,255,255,0.15);
  border-color: var(--color-white);
  color: var(--color-white);
}

.section-title {
  text-align: center;
  margin-bottom: 2.5rem;
}

.cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
}
.card {
  background: var(--color-white);
  border: 1px solid var(--gray-200);
  border-radius: 8px;
  padding: 1.75rem 1.5rem;
  text-align: center;
}
.card__icon { font-size: 2.25rem; margin-bottom: 0.75rem; }
.card h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }

.service-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.service-tile {
  display: block;
  background: var(--gray-50);
  border: 2px solid var(--gray-200);
  border-radius: 8px;
  padding: 1.75rem 1.5rem;
  text-align: center;
  text-decoration: none;
  transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
}
.service-tile:hover {
  border-color: var(--color-blue);
  transform: translateY(-3px);
  box-shadow: 0 6px 20px rgba(30,95,173,0.12);
}
.service-tile__icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
.service-tile h3 { margin-bottom: 0.5rem; }
.service-tile p { color: var(--text-mid); font-size: 0.95rem; }

.center-action { text-align: center; }

.sell-band__inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}
.sell-band__text { flex: 1 1 300px; }
.sell-band__text h2 { margin-bottom: 1rem; }
.sell-band__text p { margin-bottom: 1.5rem; font-size: 1.05rem; color: var(--text-mid); }
.sell-band__icon { font-size: 5rem; flex-shrink: 0; }
@media (max-width: 600px) {
  .sell-band__icon { display: none; }
}

.cta-band { text-align: center; }
.cta-band h2 { color: var(--color-white); margin-bottom: 0.75rem; }
.cta-band p { color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
</style>
