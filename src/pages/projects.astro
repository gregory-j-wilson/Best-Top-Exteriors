---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Past Projects" description="See past roofing, gutters, siding, and painting projects from Best Top Exteriors in Wichita, KS.">

  <!-- Hero -->
  <section class="section section--navy page-hero">
    <div class="container">
      <h1>Past Projects</h1>
      <p>Quality work for homeowners across the Wichita area.</p>
    </div>
  </section>

  <!-- Our Past Work -->
  <section class="section section--white">
    <div class="container">
      <h2 class="section-title">Our Past Work</h2>
      <div class="past-work">
        <img
          class="past-work__img"
          src="https://images.pexels.com/photos/1396132/pexels-photo-1396132.jpeg?auto=compress&cs=tinysrgb&w=1200&h=600&fit=crop"
          alt="Attractive suburban home with well-maintained exterior"
          loading="lazy"
          width="1200"
          height="600"
        />
        <p class="past-work__text">Over the years, we've had the privilege of completing quality exterior projects for homeowners throughout Wichita and the surrounding communities. From full roof replacements and seamless gutter installs to fresh coats of paint and new siding — we take pride in every job we take on, no matter the size. Our goal is always the same: leave every home better than we found it, and every homeowner glad they called us.</p>
        <p class="past-work__text past-work__text--cta">Photos of our work are coming soon. In the meantime, <a href="/contact">reach out</a> and we'd be happy to talk through what we can do for your home.</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section--gray200">
    <div class="container">
      <h2 class="section-title">What Our Customers Say</h2>
      <p class="reviews-note">We've been proud to serve many homeowners across the Wichita area. Customer reviews coming soon — in the meantime, give us a call and we're happy to talk through our work.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--navy cta-band">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Get your free estimate today — no pressure, no obligation.</p>
      <a href="/contact" class="btn btn--primary">Request a Free Estimate</a>
    </div>
  </section>

</Layout>

<style>
.page-hero { text-align: center; }
.page-hero p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin-top: 0.75rem; }

.section-title { text-align: center; margin-bottom: 2.5rem; }

.past-work {
  max-width: 860px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}

.past-work__img {
  width: 100%;
  height: 400px;
  object-fit: cover;
  border-radius: 10px;
  display: block;
}

.past-work__text {
  font-size: 1.05rem;
  color: var(--text-mid);
  line-height: 1.75;
  text-align: center;
}

.past-work__text--cta {
  color: var(--text-light);
  font-size: 1rem;
}

.past-work__text--cta a {
  color: var(--color-blue);
  text-decoration: underline;
}

.reviews-note {
  text-align: center;
  max-width: 600px;
  margin: 0 auto;
  font-size: 1.05rem;
  color: var(--text-mid);
}

.cta-band { text-align: center; }
.cta-band h2 { color: var(--color-white); margin-bottom: 0.75rem; }
.cta-band p { color: rgba(255,255,255,0.8); margin-bottom: 2rem; }
</style>
