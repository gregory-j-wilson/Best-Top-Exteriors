---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'roofing',
    icon: '🏚️',
    title: 'Roofing',
    img: '7788264',
    imgAlt: 'Construction worker on a residential roof',
    description: 'Your roof is your home\'s first line of defense. We handle everything from minor repairs to complete replacements — and we work directly with your insurance company to make sure you\'re treated fairly after storm damage.',
    items: ['Hail-damaged shingle repair & replacement', 'Wind-damaged & missing shingle repair', 'Tree damage repair', 'Leak detection & repair', 'Roof inspections', 'Ventilation improvements'],
  },
  {
    id: 'gutters',
    icon: '🌧️',
    title: 'Gutters',
    img: '5071177',
    imgAlt: 'House exterior showing roofline and gutters',
    description: 'Properly functioning gutters protect your foundation, siding, and landscaping. We install, repair, and clean gutter systems for homes of all sizes.',
    items: ['Seamless gutter installation', 'Gutter cleaning & flushing', 'Downspout installation & repair', 'Gutter guard systems', 'Soffit & fascia board repair', 'Window trim & window sill repair'],
  },
  {
    id: 'siding',
    icon: '🏗️',
    title: 'Siding',
    img: '6422929',
    imgAlt: 'House exterior with blue siding during daytime',
    description: 'From rotted boards to cracks and holes, we repair and replace all types of siding — wood, vinyl, and more. New siding transforms the look of your home while adding insulation and weather protection.',
    items: ['Rotted siding repair & replacement', 'Crack & hole repair', 'Wood siding repair', 'Vinyl siding installation & repair', 'Storm damage assessment', 'Trim & accent work'],
  },
  {
    id: 'painting',
    icon: '🎨',
    title: 'Interior & Exterior Painting',
    img: '1917849',
    imgAlt: 'Man painting a house exterior with a roller',
    description: 'A fresh coat of paint is one of the most impactful upgrades you can make. We power wash your house and wood deck and handle all the prep work so the finish looks great and lasts.',
    items: ['Exterior house painting', 'Interior room painting', 'Trim & detail work', 'Deck & fence staining', 'Power washing — house & wood decks', 'Surface prep & priming'],
  },
];
---

<Layout title="Our Services" description="Roofing, gutters, siding, and painting services from Best Top Exteriors in Wichita, KS.">

  <!-- Hero -->
  <section class="section section--navy page-hero">
    <div class="container">
      <h1>Our Services</h1>
      <p>Quality exterior work for Wichita homeowners — done right, every time.</p>
    </div>
  </section>

  <!-- Services -->
  {services.map((service, i) => (
    <section id={service.id} class:list={['section', i % 2 === 0 ? 'section--white' : 'section--gray100']}>
      <div class="container service-block">
        {service.img && (
          <img
            class="service-hero-img"
            src={`https://images.pexels.com/photos/${service.img}/pexels-photo-${service.img}.jpeg?auto=compress&cs=tinysrgb&w=1200&h=400&fit=crop`}
            alt={service.imgAlt}
            loading="lazy"
            width="1200"
            height="400"
          />
        )}
        <div class="service-block__header">
          <span class="service-block__icon">{service.icon}</span>
          <h2>{service.title}</h2>
        </div>
        <div class="service-block__body">
          <p class="service-block__desc">{service.description}</p>
          <ul class="service-list">
            {service.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <div class="service-block__cta">
          <a href="/contact" class="btn btn--primary">Get an Estimate</a>
        </div>
      </div>
    </section>
  ))}

  <!-- Leak Detection Callout -->
  <section class="section section--navy leak-band">
    <div class="container">
      <div class="leak-band__inner">
        <div class="leak-band__icon">🔍</div>
        <div>
          <h2>Experts at Finding &amp; Fixing Leaks</h2>
          <p>Whether it's your roof, windows, or siding — we're experts at tracking down the source of leaks and fixing them right the first time.</p>
        </div>
        <a href="/contact" class="btn btn--primary">Schedule an Inspection</a>
      </div>
    </div>
  </section>

  <!-- Additional Services -->
  <section id="additional" class="section section--white">
    <div class="container service-block">
      <div class="service-block__header">
        <span class="service-block__icon">🔧</span>
        <h2>Additional Services</h2>
      </div>
      <div class="service-block__body">
        <p class="service-block__desc">Beyond our core offerings, we provide a range of additional services to keep your property in top shape — including helping homeowners get ready to sell.</p>
        <ul class="service-list">
          <li>Fence repairs</li>
          <li>Window & trim wrapping</li>
          <li>Free pre-sale home inspections</li>
          <li>Realtor partnership — getting your property market-ready</li>
        </ul>
      </div>
      <div class="service-block__cta">
        <a href="/contact" class="btn btn--primary">Ask About Additional Services</a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section section--blue cta-band">
    <div class="container">
      <h2>Not Sure What You Need?</h2>
      <p>Give us a call or send us a message. We're happy to walk through your home and give an honest assessment.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn--primary">Contact Us</a>
        <a href="tel:3168699613" class="btn btn--outline-white">316-869-9613</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.page-hero { text-align: center; }
.page-hero p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin-top: 0.75rem; }

.service-hero-img {
  width: 100%;
  height: 320px;
  object-fit: cover;
  border-radius: 10px;
  display: block;
}

.service-block {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.service-block__header {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.service-block__icon { font-size: 2.5rem; }
.service-block__header h2 { margin: 0; }

.service-block__desc {
  font-size: 1.05rem;
  max-width: 700px;
  margin-bottom: 1rem;
}

.service-list {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 0.5rem 2rem;
}
.service-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  font-size: 0.95rem;
  color: var(--text-mid);
  padding: 0.25rem 0;
}
.service-list li::before {
  content: '✓';
  color: var(--color-blue);
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}

.service-block__cta { margin-top: 0.5rem; }

.leak-band { padding: 3rem 2rem; }
.leak-band__inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1.5rem 2.5rem;
}
.leak-band__icon { font-size: 2.5rem; flex-shrink: 0; }
.leak-band__inner h2 { color: var(--color-white); margin-bottom: 0.4rem; font-size: 1.5rem; }
.leak-band__inner p { color: rgba(255,255,255,0.85); max-width: 520px; }
.leak-band__inner > div { flex: 1 1 300px; }
@media (max-width: 640px) {
  .leak-band__icon { display: none; }
  .leak-band__inner { flex-direction: column; align-items: flex-start; }
}

.cta-band { text-align: center; }
.cta-band h2 { color: var(--color-white); margin-bottom: 0.75rem; }
.cta-band p { color: rgba(255,255,255,0.85); margin-bottom: 2rem; }
.cta-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
}
.btn--outline-white {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  border-radius: 4px;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1rem;
  background: transparent;
  color: var(--color-white);
  border: 2px solid rgba(255,255,255,0.7);
  text-decoration: none;
  transition: background 0.2s, border-color 0.2s;
}
.btn--outline-white:hover {
  background: rgba(255,255,255,0.15);
  border-color: var(--color-white);
  color: var(--color-white);
}
</style>
